# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_CONNECTION=pg
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DB_NAME=TIBOX

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Attachment storage (mount this path as a persistent volume in production)
ATTACHMENT_DISK=local
UPLOADS_PATH=storage/uploads

LIMITER_STORE=database
